<UserControl x:Class="Felweed.Views.MainMenu.Scripts.BackendDepActualizerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
             xmlns:scripts="clr-namespace:Felweed.ViewModels.MainMenu.Scripts"
             d:DataContext="{d:DesignInstance Type=scripts:BackendDepActualizerPageVm, IsDesignTimeCreatable=True}"
             d:DesignHeight="808"
             d:DesignWidth="880">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localConverters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <localConverters:InverseNullableBooleanToVisibilityConverter x:Key="InverseNullableBooleanToVisibilityConverter"/>
        <localConverters:SolutionActualizeStatusToIconConverter x:Key="SolutionActualizeStatusToIconConverter"/>
        <localConverters:SolutionActualizeStatusToVisibilityConverter x:Key="SolutionActualizeStatusToVisibilityConverter" />
        <localConverters:SolutionActualizeStatusToForegroundConverter  x:Key="SolutionActualizeStatusToForegroundConverter"/>
        <localConverters:InvertVisibilityConverter x:Key="InvertVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid Margin="16">
        <ui:ProgressRing IsIndeterminate="True"
                      Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        
        <Grid Visibility="{Binding IsProcessing, Converter={StaticResource InverseNullableBooleanToVisibilityConverter}}">
            <ui:TextBlock Visibility="{Binding IsInitialized, Converter={StaticResource InverseNullableBooleanToVisibilityConverter}}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Text="{Binding InitError}"/>
            
            <Grid Visibility="{Binding IsInitialized, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <GroupBox Header="Выбор зависимостей через DAG" Padding="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                        <ComboBox x:Name="ActualizeSolutionFilter"
                                  Width="320"
                                  ItemsSource="{Binding ActualizeSolutions}"
                                  SelectedItem="{Binding DagFilterSolution}"
                                  IsEnabled="{Binding ActualizeViewEnabled}"
                                  DisplayMemberPath="Solution.Name"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="Solution.Name"
                                  StaysOpenOnEdit="True"/>

                        <Button Content="Применить" Margin="16,0,0,0"
                                VerticalContentAlignment="Center"
                                VerticalAlignment="Stretch"
                                IsEnabled="{Binding ActualizeViewEnabled}"
                                Command="{Binding UseDagFilterSelectionCommand}"/>
                    </StackPanel>
                </GroupBox>
                
                <GroupBox Grid.Row="1" Header="Выбор зависимостей вручную" Padding="8">
                    <ui:ListView ItemsSource="{Binding ActualizeSolutions}"
                                 SelectionMode="Multiple"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 IsEnabled="{Binding ActualizeViewEnabled}">
                        <ui:ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsChecked, Mode=TwoWay}" />
                                
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnPreviewMouseRightButtonDown" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding Solution.Name}"
                                                      Focusable="False"
                                                      IsEnabled="False"
                                                      FontWeight="SemiBold"/>
                                            <Separator/>
                                            <ui:MenuItem Header="Игнорировать при обновлении" 
                                                         Visibility="{Binding IsIgnoredAsDep, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                         Command="{Binding SetIgnoredAsDepCommand}" />
                                            <ui:MenuItem Header="Перестать игнорировать при обновлении" 
                                                         Visibility="{Binding IsIgnoredAsDep, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                         Command="{Binding SetNotIgnoredAsDepCommand}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Solution.IsRunnable}" Value="True">
                                        <Setter Property="ContextMenu" Value="{x:Null}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:ListView.ItemContainerStyle>
                        
                        <ui:ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Vertical" 
                                           Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}" />
                            </ItemsPanelTemplate>
                        </ui:ListView.ItemsPanel>
                        
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type scripts:SolutionActualizeVm}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:ProgressRing Grid.Column="0" IsIndeterminate="True"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="8"
                                                     HorizontalAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsEnabled="False"
                                              HorizontalAlignment="Center"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsChecked}"
                                              Visibility="{Binding Visibility, ElementName=SolutionActualizeStatusIcon, Converter={StaticResource InvertVisibilityConverter}}"
                                    />
                                    
                                    <ui:SymbolIcon Grid.Column="0" 
                                                   Width="16"
                                                   Height="16"
                                                   Margin="8"
                                                   x:Name="SolutionActualizeStatusIcon"
                                                   Symbol="{Binding Status, Converter={StaticResource SolutionActualizeStatusToIconConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource SolutionActualizeStatusToForegroundConverter}}"
                                                   Visibility="{Binding Status, Converter={StaticResource SolutionActualizeStatusToVisibilityConverter}}"/>
                                
                                    <TextBlock Grid.Column="1" Text="{Binding Solution.Name}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <!-- Default (Unchecked) -->
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIgnoredAsDep}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ui:ListView>
                </GroupBox>
                
                <GroupBox Header="Управление" Grid.Row="2" Margin="0, 8, 0, 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Vertical" Grid.Column="0">
                            <CheckBox Content="Пропустить проверку сборки (dotnet build)"
                                      IsEnabled="{Binding ActualizeViewEnabled}"
                                      IsChecked="{Binding SkipBuild}"/>
                    
                            <CheckBox Content="Пререлизы (rc)" 
                                      Margin="0, 0, 0, 0"
                                      IsEnabled="{Binding ActualizeViewEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsChecked="{Binding IncludePreRelease}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <ui:Button Content="Запустить актуализацию" 
                                       Command="{Binding ActualizeBackendDepsCommand}"
                                       Margin="16, 0, 0, 0"
                                       Cursor="Hand">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Play24" />
                                </ui:Button.Icon>
                            </ui:Button>
                    
                            <ui:Button Content="Прервать актуализацию" 
                                       Command="{Binding InterruptBackendDepsActualizationCommand}"
                                       IsEnabled="{Binding CanInterruptActualization}"
                                       Margin="16, 8, 0, 0"
                                       Cursor="Hand">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Stop24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            
                            <ui:Button Content="Показать лог" 
                                       Command="{Binding ShowResultDialogCommand}"
                                       Margin="16, 8, 0, 0"
                                       Cursor="Hand">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Info24" />
                                </ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
