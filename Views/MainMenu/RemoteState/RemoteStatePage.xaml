<Page x:Class="Felweed.Views.MainMenu.RemoteState.RemoteStatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
      xmlns:remoteState="clr-namespace:Felweed.ViewModels.MainMenu.RemoteState"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=remoteState:RemoteStatePageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="808"
      d:DesignWidth="880"
      ScrollViewer.CanContentScroll="False"
      Title="RemoteStatePage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localConverters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
        <localConverters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <localConverters:SolutionTypeToIconConverter x:Key="SolutionTypeToIconConverter"/>
        <localConverters:SolutionTypeToTooltipConverter x:Key="SolutionTypeToTooltipConverter"/>
        <localConverters:GitlabJobStatusToIconConverter x:Key="GitlabJobStatusToIconConverter"/>
        <localConverters:SolutionOutdatedToColorConverter x:Key="SolutionOutdatedToColorConverter"/>
        <localConverters:SolutionKindToWatermarkTextConverter x:Key="SolutionKindToWatermarkTextConverter"/>
    </Page.Resources>
    
    <Grid>
        <!-- Loading Overlay -->
        <StackPanel Margin="20,0,20,20"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True" />
            
            <ui:TextBlock Text="Подключение..." 
                          Margin="0,10,0,0" 
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Center" />
        </StackPanel>
        
        <Grid Margin="20,0,20,20" Visibility="{Binding IsError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:TextBlock Text="{Binding Error}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Grid>
        
        <Grid Margin="20,0,20,20" Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:TextBlock Visibility="{Binding State, Converter={StaticResource InverseNullToVisibilityConverter}}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}">Ожидание данных...</ui:TextBlock>
            
            <Grid Visibility="{Binding State, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid Margin="20,0,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:DataGrid Grid.Row="1" 
                                 x:Name="SolutionDataGrid"
                                 RowDetailsVisibilityMode="VisibleWhenSelected"
                                 EnableRowVirtualization="True"
                                 ItemsSource="{Binding Solutions}" 
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False"
                                 VerticalAlignment="Top">
                        <ui:DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent" VerticalAlignment="Stretch">
                                            <TextBlock Text="{Binding Kind, Converter={StaticResource SolutionKindToWatermarkTextConverter}}" 
                                                       FontSize="24"
                                                       Padding="0"
                                                       Margin="0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       Opacity="0.1" 
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Name" Width="*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent" VerticalAlignment="Stretch">
                                            <ui:SymbolIcon Symbol="{Binding Type, Converter={StaticResource SolutionTypeToIconConverter}}" 
                                                           ToolTip="{Binding Type, Converter={StaticResource SolutionTypeToTooltipConverter}}"
                                                           FontSize="24"
                                                           Foreground="Gray"
                                                           HorizontalAlignment="Left"
                                                           Opacity="0.3" />
                                            
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Padding="12,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Proxy DP that can host DynamicResource -->
                            <DataGridTextColumn x:Name="PrimaryBrushProxy"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Visibility="Collapsed" />
                            
                            <DataGridTextColumn Header="Version" IsReadOnly="True" Binding="{Binding TagVersionNumber}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource SolutionOutdatedToColorConverter}">
                                                    <Binding Path="IsOutdated"/>
                                                    <Binding ElementName="PrimaryBrushProxy" Path="Foreground" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="Last Sync" IsReadOnly="True" Binding="{Binding LatestSyncDate, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="160" />
                        </ui:DataGrid.Columns>
                        
                        <ui:DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Visibility="{Binding CobwebProject, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Grid>
                                            <ui:HyperlinkButton Icon="{ui:SymbolIcon Link24}"
                                                                Content="В репозиторий"
                                                                NavigateUri="{Binding CobwebProject.WebUrl, FallbackValue={x:Null}}"
                                                                Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                FontSize="18"
                                            />
                                        </Grid>
                                        
                                        <Grid Grid.Column="1">
                                            <ui:HyperlinkButton Icon="{ui:SymbolIcon Link24}"
                                                                Content="В пайплайны"
                                                                NavigateUri="{Binding PipelineUrl, FallbackValue={x:Null}}"
                                                                Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                FontSize="18"
                                            />
                                        </Grid>
                                    </Grid>
                                    
                                    <ui:DataGrid Grid.Row="1"
                                                ItemsSource="{Binding CobwebProject.Tags, FallbackValue={x:Null}}"
                                                 AutoGenerateColumns="False"
                                                 HeadersVisibility="None"
                                                 CanUserAddRows="False"
                                                 IsReadOnly="True"
                                                 MaxHeight="320"
                                                 RowHeight="24"
                                                 Margin="32,4,0,8">
                                        <ui:DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="FontSize" Value="8" />
                                                <Setter Property="MinHeight" Value="24" />
                                                <Setter Property="Opacity" Value="0.7" />
                                            </Style>
                                        </ui:DataGrid.RowStyle>
                                        
                                        <ui:DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Padding" Value="4,0" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                        </ui:DataGrid.CellStyle>
                                        
                                        <ui:DataGrid.Columns>
                                            <DataGridTextColumn IsReadOnly="True" Binding="{Binding Name}" />
                                            <DataGridTextColumn IsReadOnly="True" Binding="{Binding AuthorUsername}" />
                                            <DataGridTextColumn IsReadOnly="True" Binding="{Binding CreatedAt}" />
                                            <DataGridTemplateColumn IsReadOnly="True" >
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <svgc:SvgViewbox
                                                            Width="16"
                                                            Height="16"
                                                            Margin="0,2,8,0"
                                                            VerticalAlignment="Center"
                                                            Source="{Binding LatestPublishStatus, Converter={StaticResource GitlabJobStatusToIconConverter}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </ui:DataGrid.Columns>
                                    </ui:DataGrid>
                                </Grid>
                            </DataTemplate>
                        </ui:DataGrid.RowDetailsTemplate>
                    </ui:DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
