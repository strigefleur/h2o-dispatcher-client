<UserControl x:Class="Felweed.Views.Dialogs.ProfileSelectorDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Felweed.Views.Dialogs"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
             xmlns:dialogs="clr-namespace:Felweed.ViewModels.Dialogs"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=dialogs:ProfileSelectorDialogVm, IsDesignTimeCreatable=True}"
             Width="800"
             Height="400"
             d:DesignWidth="800">
    <UserControl.Resources>
        <localConverters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        
        <ui:ListView ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     x:Name="ProfileListView"
                     SelectionMode="Single">
            
            <ui:ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type dialogs:AppProfileConfigVm}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        
                        <ui:TextBlock Text="{Binding Name}"
                                      Margin="8,8,0,0"
                                      FontWeight="SemiBold"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        
                        <ui:TextBlock Grid.Row="1" Text="{Binding Description}"
                                      Margin="8,0,0,0"
                                      FontSize="12"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>
        
        <StackPanel Grid.Column="1" Margin="8,0" DataContext="{Binding SelectedProfile}"
                    x:Name="SelectedProfilePanel"
                    Visibility="{Binding ., TargetNullValue=Collapsed, Converter={StaticResource NullToVisibilityConverter}}">
            <ui:Card>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" Text="CSharpCorporateL0Prefix"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CSharpCorporateL0Prefix}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Text="CSharpCorporateL1Prefix"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CSharpCorporateL1Prefix}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <ui:TextBlock Grid.Row="2" Grid.Column="0" Text="AngularCorporateL0Prefix"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AngularCorporateL0Prefix}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <ui:TextBlock Grid.Row="3" Grid.Column="0" Text="AngularCorporateL1Prefix"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AngularCorporateL1Prefix}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <ui:TextBlock Grid.Row="4" Grid.Column="0" Text="ActiveBranch"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ActiveBranch}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <ui:TextBlock Grid.Row="5" Grid.Column="0" Text="DepsGoogleTableUrl"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DepsGoogleTableUrl}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ui:DataGrid Grid.Row="0" ItemsSource="{Binding SolutionDirectories}"
                                 AutoGenerateColumns="False"
                                 RowHeaderWidth="0"
                                 SelectionUnit="Cell"
                                 HeadersVisibility="None">
                        <ui:DataGrid.Columns>
                            <DataGridTextColumn IsReadOnly="True" Binding="{Binding}" Width="*" />
                            
                            <DataGridTemplateColumn Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                Command="{Binding DataContext.RemovePathCommand, ElementName=SelectedProfilePanel}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Добавить каталог" Command="{Binding AddPathCommand}" />
                    </StackPanel>
                </Grid>
            </ui:Card>
        </StackPanel>
    </Grid>
</UserControl>
