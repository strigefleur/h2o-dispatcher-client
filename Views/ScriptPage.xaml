<Page x:Class="Felweed.Views.ScriptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Felweed.Views"
      xmlns:m="clr-namespace:Felweed.Models"
      xmlns:vm="clr-namespace:Felweed.ViewModels"
      xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:ScriptPageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="808"
      d:DesignWidth="880"
      ScrollViewer.CanContentScroll="False"
      Title="ScriptPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localConverters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Page.Resources>
    
    <Grid>
        <ui:TextBlock Text="Не задан API ключ Gitlab" 
                      VerticalAlignment="Center"
                      Visibility="{Binding IsInit, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                      HorizontalAlignment="Center" />
        
        <TabControl Margin="8" Visibility="{Binding IsInit, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TabItem ToolTip="Актуализировать зависимости (фронт)">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Braces24" />
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowArrowUp24" />
                    </StackPanel>
                </TabItem.Header>
                
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <local:FrontendDepActualizer/>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>
            
            <TabItem ToolTip="Актуализировать зависимости (бэк)">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Server24" />
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowArrowUp24" />
                    </StackPanel>
                </TabItem.Header>
                
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <local:BackendDepActualizer/>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>
            
            <TabItem ToolTip="Для каждого репозитория">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowMultiple20" />
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DocumentEdit24" />
                    </StackPanel>
                </TabItem.Header>
                
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <local:BatchRepoAction/>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
