<Page x:Class="Felweed.Views.RemoteStatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Felweed.Views"
      xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
      xmlns:vm="clr-namespace:Felweed.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:RemoteStatePageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="808"
      d:DesignWidth="880"
      Title="RemoteStatePage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localConverters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
        <localConverters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Page.Resources>
    
    <Grid>
        <!-- Loading Overlay -->
        <StackPanel Margin="20,0,20,20"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True" />
            
            <ui:TextBlock Text="Подключение..." 
                          Margin="0,10,0,0" 
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Center" />
        </StackPanel>
        
        <Grid Margin="20,0,20,20" Visibility="{Binding IsError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:TextBlock Text="{Binding Error}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Grid>
        
        <Grid Margin="20,0,20,20" Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:TextBlock Visibility="{Binding State, Converter={StaticResource InverseNullToVisibilityConverter}}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}">Ожидание данных...</ui:TextBlock>
            
            <ui:TextBlock Visibility="{Binding State, Converter={StaticResource NullToVisibilityConverter}}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}">Ok</ui:TextBlock>
        </Grid>
    </Grid>
</Page>
