<Page x:Class="Felweed.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Felweed.Views"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:m="clr-namespace:Felweed.Models"
      xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
      xmlns:vm="clr-namespace:Felweed.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:AboutPageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="808"
      d:DesignWidth="880"
      Title="AboutPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localConverters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Page.Resources>
    
    <Grid Margin="32">
        <Grid Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="H2.0" 
                       FontSize="340"
                       Padding="0"
                       Margin="0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Opacity="0.05" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Grid>
        
        <StackPanel Width="540" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ui:TextBlock Text="Добро пожаловать." 
                          VerticalAlignment="Top"
                          FontWeight="SemiBold"
                          FontSize="16"
                          TextWrapping="Wrap"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Left" />
            <ui:TextBlock Text="Перед тобой - менеджер для работы с зоопарком репозиториев, составляющих проект Н2.0." 
                          Margin="0, 20, 0, 0"
                          TextWrapping="Wrap"
                          VerticalAlignment="Top"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Left" />
            <ui:TextBlock Text="Когда-нибудь здесь, может быть, появится очень полезное описание его функций, а пока - анекдот!" 
                          Margin="0, 8, 0, 0"
                          TextWrapping="Wrap"
                          VerticalAlignment="Top"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Left" />
            
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <ui:TextBlock Text="{Binding Anecdote}" 
                          Margin="0, 8, 0, 0"
                          TextWrapping="Wrap"
                          FontStyle="Italic"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                          VerticalAlignment="Top"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          HorizontalAlignment="Left" />
        </StackPanel>
        
        <Grid Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <TextBlock Text="{Binding AnecdoteSponsorText}" 
                       FontSize="10"
                       Padding="0"
                       Margin="0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Visibility="{Binding HasAnecdoteSponsor}"
                       Opacity="0.8" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</Page>
