<ui:FluentWindow x:Class="Felweed.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
                 xmlns:vm="clr-namespace:Felweed.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}"
                 xmlns:v="clr-namespace:Felweed.Views"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 ContentRendered="MainWindow_OnContentRendered"
                 Title="H2.0: Диспетчер"
                 Height="808"
                 Width="880">
    <Window.Resources>
        <localConverters:KindToIconConverter x:Key="KindToIconConverter"/>
        <localConverters:SolutionTypeToVisibilityConverter x:Key="SolutionTypeToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar>
            <ui:TitleBar.Header>
                <Grid VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/Assets/Icons/h2o_logo.svg}" 
                               Width="16" 
                               Height="16" 
                               Margin="0,2,8,0"
                               VerticalAlignment="Center" />
                        
                        <TextBlock Text="H2.0: Диспетчер" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        
        <!-- Solution Path Selector -->
        <Grid Grid.Row="1" Margin="20,0,20,20" Visibility="{Binding IsSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <v:SetupDialog DataContext="{Binding SetupDialogViewModel}" HorizontalAlignment="Stretch" />
            
            <Button Grid.Row="1" Content="Confirm" IsDefault="True"
                    Command="{Binding ConfirmSelectorCommand}"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"/>
        </Grid>
        
        <!-- Loading Overlay -->
        <StackPanel Grid.Row="1" Margin="20,0,20,20"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True" />
            
            <TextBlock Text="Scanning for solutions..." 
                       Margin="0,10,0,0" 
                       HorizontalAlignment="Center" />
        </StackPanel>
        
        <Grid Grid.Row="1" Margin="20,0,20,20" Visibility="{Binding IsLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:DataGrid Grid.Row="1" 
                         ItemsSource="{Binding Solutions}" 
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         VerticalAlignment="Top">
                <ui:DataGrid.Columns>
                    <!-- Kind Icon -->
                    <DataGridTemplateColumn Header="Kind" Width="80" SortMemberPath="Kind">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:SymbolIcon Symbol="{Binding Kind, Converter={StaticResource KindToIconConverter}}" 
                                               FontSize="18" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" FontWeight="SemiBold" Width="*" />
                    <DataGridTextColumn Header="Version" Binding="{Binding ChangelogVersionNumber}" Width="100" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                    <DataGridTextColumn Header="Last Sync" Binding="{Binding LatestSyncDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="120" />

                    <!-- Action Button -->
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button Content="Run" 
                                           Appearance="Primary"
                                           Visibility="{Binding Type, Converter={StaticResource SolutionTypeToVisibilityConverter}}"
                                           Command="{Binding DataContext.RunSolutionCommand, RelativeSource={RelativeSource AncestorType=ui:DataGrid}}"
                                           CommandParameter="{Binding}" >
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Play24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Grid>
    </Grid>
</ui:FluentWindow>
