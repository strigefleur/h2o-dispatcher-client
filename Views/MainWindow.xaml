<ui:FluentWindow x:Class="Felweed.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
                 xmlns:vm="clr-namespace:Felweed.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}"
                 xmlns:v="clr-namespace:Felweed.Views"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 ContentRendered="MainWindow_OnContentRendered"
                 Title="H2.0: Диспетчер"
                 Icon="/Assets/Icons/h2o_logo.ico"
                 Height="808"
                 Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar>
            <ui:TitleBar.Header>
                <Grid VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{svgc:SvgImage Source=/Assets/Icons/h2o_logo.svg}" 
                               Width="16" 
                               Height="16" 
                               Margin="0,2,8,0"
                               VerticalAlignment="Center" />
                        
                        <TextBlock Text="H2.0: Диспетчер" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
            
            <ui:TitleBar.TrailingContent>
                <StackPanel VerticalAlignment="Top" 
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    
                    <ui:Button x:Name="ThemeToggleButton"
                               Appearance="Transparent"
                               Icon="{Binding ThemeSwitchIcon}"
                               Command="{Binding SwitchThemeCommand}"
                               ToolTip="Переключить тему"
                               Padding="0"
                               BorderThickness="0"
                               CornerRadius="0"
                               Focusable="False"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               VerticalAlignment="Stretch"
                               Cursor="Hand"

                               Width="46"
                               Height="32">
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>
        
        <!-- Solution Path Selector -->
        <Grid Grid.Row="1" Margin="20,0,20,20" Visibility="{Binding IsSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <v:SetupDialog DataContext="{Binding SetupDialogViewModel}" HorizontalAlignment="Stretch" />
            
            <Button Grid.Row="1" Content="Confirm" IsDefault="True"
                    Command="{Binding ConfirmSelectorCommand}"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"/>
        </Grid>
        
        <!-- Loading Overlay -->
        <StackPanel Grid.Row="1" Margin="20,0,20,20"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True" />
            
            <TextBlock Text="Scanning for solutions..." 
                       Margin="0,10,0,0" 
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
        
        <Grid Grid.Row="1" Margin="20,0,20,20" Visibility="{Binding IsLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:NavigationView
                x:Name="RootNavigation"
                MinHeight="300"
                Margin="0"
                IsBackButtonVisible="Collapsed"
                IsPaneToggleVisible="True"
                PaneDisplayMode="Left">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem
                        Content="Список решений"
                        Icon="{ui:SymbolIcon AppsListDetail24}"
                        TargetPageType="{x:Type v:SolutionGridPage}" />
                    <ui:NavigationViewItem
                        Content="Gitlab"
                        IsEnabled="False"
                        Icon="{ui:SymbolIcon PlugConnected24}"
                        TargetPageType="{x:Type v:RemoteStatePage}" />
                    <ui:NavigationViewItem
                        Content="Зависимости (DAG)"
                        IsExpanded="True"
                        Icon="{ui:SymbolIcon Link24}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem
                                Content="Backend"
                                x:Name="BackendGraphPage"
                                Icon="{ui:SymbolIcon Settings24}"
                                PreviewMouseUp="BackendGraphPage_OnPreviewMouseUp"
                                TargetPageType="{x:Type v:GraphPage}"
                                />
                            
                            <ui:NavigationViewItem
                                Content="Frontend"
                                x:Name="FrontendGraphPage"
                                Icon="{ui:SymbolIcon Library24}"
                                PreviewMouseUp="FrontendGraphPage_OnPreviewMouseUp"
                                TargetPageType="{x:Type v:GraphPage}"
                                />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem
                        Content="Скрипты"
                        Icon="{ui:SymbolIcon DocumentPageNumber24}"
                        TargetPageType="{x:Type v:ScriptPage}" />
                    <ui:NavigationViewItem
                        Content="Настройки"
                        IsExpanded="True"
                        Icon="{ui:SymbolIcon Settings24}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem
                                Content="Переменные окружения"
                                x:Name="EnvVariablesPage"
                                Icon="{ui:SymbolIcon Layer24}"
                                TargetPageType="{x:Type v:EnvVariablesPage}"
                            />
                            <ui:NavigationViewItem
                                Content="Прочее"
                                x:Name="MiscConfigPage"
                                Icon="{ui:SymbolIcon SettingsChat24}"
                                TargetPageType="{x:Type v:MiscSettingsPage}"
                            />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem
                        Content="О программе"
                        Icon="{ui:SymbolIcon Info24}"
                        TargetPageType="{x:Type v:AboutPage}" />
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.Header>
                    <ui:HyperlinkButton
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch"
                        Content="Зависимости (Google Table)"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://docs.google.com/spreadsheets/d/1qGU-xha3lHp07vbx6qH-VSikyNL4yQ8LLCzqpGbWOtw" />
                </ui:NavigationView.Header>
                <ui:NavigationView.PaneFooter>
                    <TextBlock
                        Margin="0,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                        Text="0.10.0" />
                </ui:NavigationView.PaneFooter>
            </ui:NavigationView>
        </Grid>
        
        <ui:ContentDialogHost x:Name="RootContentDialogHost"
                              Grid.Row="0" 
                              Grid.RowSpan="2"/>
    </Grid>
</ui:FluentWindow>
