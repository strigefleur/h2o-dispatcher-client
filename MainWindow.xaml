<ui:FluentWindow x:Class="Felweed.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Felweed"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:Felweed.ViewModels"
                 xmlns:localConverters="clr-namespace:Felweed.ViewModels.Converters"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 Title="Felweed: H2.0 Manager Client" Height="450" Width="800">
    <Window.Resources>
        <localConverters:KindToIconConverter x:Key="KindToIconConverter"/>
        <localConverters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <localConverters:SolutionTypeToVisibilityConverter x:Key="SolutionTypeToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Grid>
                
        <!-- Loading Overlay -->
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True" />
            <TextBlock Text="Scanning for solutions..." 
                       Margin="0,10,0,0" 
                       HorizontalAlignment="Center" />
        </StackPanel>
        
        <Grid Margin="20" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:DataGrid Grid.Row="1" 
                         ItemsSource="{Binding Solutions}" 
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         VerticalAlignment="Top">
                <ui:DataGrid.Columns>
                    <!-- Kind Icon -->
                    <DataGridTemplateColumn Header="Kind" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:SymbolIcon Symbol="{Binding Kind, Converter={StaticResource KindToIconConverter}}" 
                                               FontSize="18" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" FontWeight="SemiBold" Width="*" />
                    <DataGridTextColumn Header="Version" Binding="{Binding ChangelogVersionNumber}" Width="100" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                    <DataGridTextColumn Header="Last Sync" Binding="{Binding LatestSyncDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="120" />

                    <!-- Action Button -->
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button Content="Run" 
                                           Icon="Play24"
                                           Appearance="Primary"
                                           Visibility="{Binding Type, Converter={StaticResource SolutionTypeToVisibilityConverter}}"
                                           Command="{Binding DataContext.RunSolutionCommand, RelativeSource={RelativeSource AncestorType=ui:DataGrid}}"
                                           CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Grid>
    </Grid>
</ui:FluentWindow>
